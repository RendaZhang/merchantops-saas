MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=merchantops
MYSQL_USER=merchantops
MYSQL_PASSWORD=merchantops
RABBITMQ_DEFAULT_USER=merchantops
RABBITMQ_DEFAULT_PASS=merchantops
TZ=Asia/Shanghai

# Local-only demo JWT secret for Docker/runtime smoke.
# Replace this in any real deployment and inject it from the runtime environment.
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional local app overrides. The API auto-loads the repository-root .env
# only for local dev-profile startup through spring-boot:run.
# Keep real provider secrets only in your local .env, never in tracked files.
#
# Recommended provider-neutral AI config for local live smoke:
# MERCHANTOPS_AI_ENABLED=true
# MERCHANTOPS_AI_PROVIDER=DEEPSEEK
# MERCHANTOPS_AI_BASE_URL=https://api.deepseek.com
# MERCHANTOPS_AI_MODEL_ID=deepseek-chat
# MERCHANTOPS_AI_API_KEY=replace-with-local-provider-key
#
# Legacy OpenAI compatibility keys remain supported:
# MERCHANTOPS_AI_OPENAI_BASE_URL=https://api.openai.com
# MERCHANTOPS_AI_OPENAI_API_KEY=replace-with-local-openai-key
#
# DeepSeek convenience aliases also work when MERCHANTOPS_AI_PROVIDER=DEEPSEEK
# and the provider-neutral keys above are left blank:
# DEEPSEEK_API_KEY=replace-with-local-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
